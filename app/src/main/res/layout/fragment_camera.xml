<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/view_finder_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:clipToOutline="true"
        app:layout_constrainedWidth="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintTop_toBottomOf="@+id/top_controls"
        app:layout_constraintBottom_toTopOf="@+id/gallery_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <com.reilandeubank.unprocess.utils.AutoFitSurfaceView
            android:id="@+id/view_finder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

        <!-- Shutter-flash overlay (briefly opaque black at the moment of exposure). -->
        <View
            android:id="@+id/overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <!-- Capture overlay. Two states:
             - SAVING: just a semi-transparent dim over the live preview
               (no spinner, no text — minimal visual noise).
             - DONE: same dim PLUS the just-saved photo shown fitCenter at
               the preview's full size. Dismissed by the capture button,
               whose text switches to "Take new" while this overlay is in
               its DONE state. Clickable=true so taps on the preview area
               can't reach the underlying surface while we're showing it. -->
        <FrameLayout
            android:id="@+id/capture_progress_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <VideoView
                android:id="@+id/capture_progress_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/capture_progress_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/progress_thumbnail_desc"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/capture_progress_play_button"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_play"
                app:tint="@android:color/black"
                app:backgroundTint="?attr/colorPrimary"
                app:fabCustomSize="72dp"
                app:maxImageSize="36dp"
                android:visibility="gone"
                android:contentDescription="Play preview video" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/lens_selector_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#26FFFFFF"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#26FFFFFF"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintBottom_toBottomOf="@+id/view_finder_container"
        app:layout_constraintStart_toStartOf="@+id/view_finder_container"
        app:layout_constraintEnd_toEndOf="@+id/view_finder_container"
        app:layout_constraintWidth_default="wrap">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/lens_selector_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/gallery_button"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_marginBottom="48dp"
        android:layout_marginStart="32dp"
        app:icon="@drawable/ic_photo"
        app:iconTint="?attr/colorOnSecondaryContainer"
        app:backgroundTint="?attr/colorSecondaryContainer"
        app:cornerRadius="26dp"
        app:iconSize="30dp"
        android:padding="0dp"
        app:iconPadding="0dp"
        app:iconGravity="textStart"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/capture_button"
        android:layout_width="0dp"
        android:layout_height="104dp"
        android:layout_marginEnd="32dp"
        android:layout_marginStart="8dp"
        android:text="@string/capture"
        android:textSize="22sp"
        app:cornerRadius="52dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/gallery_button"
        app:layout_constraintTop_toTopOf="@+id/gallery_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/gallery_button" />

    <!-- Dark semi-transparent dim overlay when settings menu is active -->
    <View
        android:id="@+id/settings_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Top control buttons drawn over the dim overlay -->
    <LinearLayout
        android:id="@+id/top_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="79dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/movie_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/flash_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

    </LinearLayout>

    <!-- Vertical settings menu panel that pops down under the settings gear -->
    <LinearLayout
        android:id="@+id/settings_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/top_controls"
        app:layout_constraintEnd_toEndOf="@+id/top_controls"
        android:layout_marginTop="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aspect_ratio_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="@string/aspect_ratio_full"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/resolution_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="1080p"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/framerate_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="30 FPS"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mode_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="end"
            android:text="JPEG"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filter_toggle"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:text="@string/filter_normal"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
